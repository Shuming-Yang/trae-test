        // ms-python.flake8
        // 功能：Python 語法檢查工具。
        // 原因：請勿安裝，本專案統一使用 Pylint，以免兩者規則衝突產生混淆。
        "ms-python.flake8",
        // ms-python.black-formatter
        // 功能：非常強勢的格式化工具，強制改成符合 PEP 8 的單一風格。
        // 原因：專案暫不強制格式化，避免 Git 變動過大；請使用 autopep8 或手動調整。
        "ms-python.black-formatter",
        // ms-python.isort
        // 功能：專門用來排序 import 的工具。
        // 原因：Pylint 有時候會檢查 import 順序，若 isort 規則與 Pylint 不一致，會導致反覆報錯與修改。
        "ms-python.isort",
        // batisteo.vscode-django
