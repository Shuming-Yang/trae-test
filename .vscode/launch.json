// A launch configuration that launches the extension inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
    "version": "0.2.0",
    "configurations": [
		{
			"name": "Python: Backend Debug",
			"type": "debugpy",
			"request": "launch",
			"program": "${workspaceFolder}/application/index.py",
			"python": "${workspaceFolder}/.venv/Scripts/python.exe",
			// "args": ["--debug"],
			"cwd": "${workspaceFolder}/application",
			"console": "internalConsole",
			"env": {
				"PYTHONPATH": "${workspaceFolder}:${workspaceFolder}/application",
                // ★ 加入這行，強制關閉緩衝
                "PYTHONUNBUFFERED": "1"
			}
		},
		{
            // 啟動 Extension 的設定
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/vscode_ext"
            ],
            "outFiles": [
                "${workspaceFolder}/vscode_ext/**/*.js"
            ]
        },
		{
            // Python 附加設定
            // 用來連接已經被 extension.js 啟動並正在等待的 Python
            "name": "Attach to Python Backend",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "justMyCode": true,
            // 如果斷點變成空心圓 (Unverified Breakpoint)，通常是路徑對應問題，需設定 pathMappings
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/application",
                    "remoteRoot": "${workspaceFolder}/application"
                }
            ]
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Open index.html",
            "file": "${workspaceFolder}/application/index.html"
        }
	],
	// 複合指令：
	"compounds": []
}
